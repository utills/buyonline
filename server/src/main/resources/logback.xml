<configuration>

    <!-- ============================================================ -->
    <!-- Console Appender with correlation ID from MDC ("request-id") -->
    <!-- ============================================================ -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{request-id}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ============================================================ -->
    <!-- Suppress noisy third-party loggers                           -->
    <!-- ============================================================ -->
    <logger name="io.netty" level="WARN"/>
    <logger name="org.jetbrains.exposed" level="WARN"/>
    <logger name="Exposed" level="WARN"/>
    <logger name="org.eclipse.jetty" level="WARN"/>

    <!-- ============================================================ -->
    <!-- Application loggers — DEBUG in development                   -->
    <!-- ============================================================ -->
    <logger name="com.prudential.health" level="DEBUG"/>

    <!-- ============================================================ -->
    <!-- Root logger                                                  -->
    <!-- ============================================================ -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
