# syntax=docker/dockerfile:1
# ─────────────────────────────────────────────────────────────
# BuyOnline Web — Multi-stage Dockerfile (Next.js standalone)
# Build context: monorepo root  (docker build -f apps/web/Dockerfile .)
# ─────────────────────────────────────────────────────────────

# ── Stage 1: base ─────────────────────────────────────────────
FROM node:22-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@10.30.1 --activate

# ── Stage 2: deps — install node_modules (cached layer) ───────
FROM base AS deps
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json                    ./apps/web/
COPY packages/shared-types/package.json       ./packages/shared-types/
COPY packages/ui/package.json                 ./packages/ui/
COPY packages/ts-config/package.json          ./packages/ts-config/

RUN pnpm install --frozen-lockfile

# ── Stage 3: builder — Next.js production build ───────────────
FROM base AS builder
WORKDIR /app

COPY --from=deps /app/node_modules            ./node_modules

COPY turbo.json                               ./
COPY apps/web                                 ./apps/web
COPY packages                                 ./packages

# Disable Next.js telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

# NEXT_PUBLIC_* vars must be available at build time
# Pass via --build-arg in CI: --build-arg NEXT_PUBLIC_API_URL=https://api-sit.example.com
ARG NEXT_PUBLIC_API_URL=http://localhost:3001
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN cd apps/web && pnpm run build

# ── Stage 4: runner — minimal Next.js standalone image ────────
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs

# Next.js standalone output (includes only necessary node_modules,
# file-tracing respects outputFileTracingRoot = monorepo root)
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone  ./

# Static assets and public folder must be copied separately
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static      ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public            ./apps/web/public

USER nextjs

EXPOSE 3000

# server.js is generated by Next.js standalone at the app's path
CMD ["node", "apps/web/server.js"]
