# Server
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://buyonline:buyonline@localhost:5432/buyonline

# Redis (for sessions/chat)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-here
OTP_EXPIRY_SECONDS=180

# Claude AI Chat — REQUIRED for chatbot to function
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CHAT_MODEL=claude-haiku-4-5-20251001
CHAT_MAX_TOKENS=1024

# CORS — set to your frontend URL in production (default: * is insecure)
CORS_ORIGIN=http://localhost:3000
